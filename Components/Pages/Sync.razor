@page "/sync"
@using wish_drom.Models
@using wish_drom.Services.Interfaces
@using wish_drom.Data
@using wish_drom.Data.Entities
@using System.Diagnostics
@using System.Text.Json
@using Microsoft.EntityFrameworkCore
@inject IDataCaptureService DataCaptureService
@inject NavigationManager Navigation

<div class="sync-page">
    @* 顶部应用栏 *@
    <header class="app-bar">
        <button class="back-btn" @onclick="@(() => NavigateBack())">
            <span class="back-icon">←</span>
        </button>
        <h1 class="app-title">数据同步</h1>
        <div class="app-bar-spacer"></div>
    </header>

    @* 内容区域 *@
    <div class="sync-content">
        @if (currentStep == SyncStep.SelectDataSource)
        {
            @* 数据源选择 - 两列网格布局 *@
            <section class="section">
                <h2 class="section-title">选择数据源</h2>
                <p class="section-desc">点击下方按钮，在 WebView 中登录并提取数据</p>

                @if (registeredSources.Any())
                {
                    <div class="datasource-grid">
                        @foreach (var source in registeredSources)
                        {
                            <button class="datasource-card" @onclick="@(() => SelectDataSource(source.Id))">
                                <div class="datasource-icon">
                                    @if (!string.IsNullOrEmpty(source.FaviconUrl))
                                    {
                                        <img src="@source.FaviconUrl" class="favicon-img" alt="@source.DisplayName" />
                                    }
                                    else
                                    {
                                        <span class="favicon-placeholder">@source.GetFaviconLetter()</span>
                                    }
                                </div>
                                <div class="datasource-info">
                                    <span class="datasource-name">@source.DisplayName</span>
                                </div>
                            </button>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <span class="empty-icon">📭</span>
                        <p class="empty-text">暂无已注册的数据源</p>
                        <p class="empty-hint">请联系管理员添加数据提供者</p>
                    </div>
                }
            </section>
        }
        else if (currentStep == SyncStep.Syncing)
        {
            @* 同步状态提示 *@
            <section class="section">
                <div class="status-container">
                    @if (isSyncing)
                    {
                        <div class="syncing-wrapper">
                            <div class="syncing-spinner">⟳</div>
                            <h3 class="status-title">正在同步</h3>
                            <p class="status-desc">请在 WebView 中完成操作</p>
                        </div>
                    }
                    else if (syncSuccess)
                    {
                        <div class="success-wrapper">
                            <div class="success-icon">✓</div>
                            <h3 class="status-title">同步成功</h3>
                            <p class="status-desc">成功同步 @syncedCourseCount 门课程</p>
                            <button class="retry-btn" @onclick="@(() => GoBack())">返回</button>
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(syncError))
                    {
                        <div class="error-wrapper">
                            <div class="error-icon">⚠️</div>
                            <h3 class="status-title">同步失败</h3>
                            <p class="status-desc">@syncError</p>
                            <button class="retry-btn" @onclick="@(() => GoBack())">返回重试</button>
                        </div>
                    }
                </div>
            </section>
        }
    </div>
</div>

<style>
    /* ==================== 主容器 ==================== */
    .sync-page {
        display: flex;
        flex-direction: column;
        height: 100%;
        background-color: #F5F5F5;
    }

    /* ==================== 应用栏 ==================== */
    .app-bar {
        display: flex;
        align-items: center;
        padding: 12px 16px;
        padding-top: max(12px, env(safe-area-inset-top));
        background-color: #2D3E5F;
        color: white;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        z-index: 10;
    }

    .back-btn {
        width: 40px;
        height: 40px;
        border: none;
        background: none;
        color: white;
        font-size: 24px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-right: 8px;
    }

    .app-title {
        font-size: 20px;
        font-weight: 600;
        margin: 0;
        flex: 1;
    }

    .app-bar-spacer {
        width: 40px;
    }

    /* ==================== 内容区域 ==================== */
    .sync-content {
        flex: 1;
        overflow-y: auto;
        -webkit-overflow-scrolling: touch;
        padding: 16px;
    }

    .section {
        margin-bottom: 24px;
    }

    .section-title {
        font-size: 22px;
        font-weight: 600;
        color: #2C2C2C;
        margin: 0 0 8px 0;
    }

    .section-desc {
        font-size: 14px;
        color: #757575;
        margin: 0 0 20px 0;
    }

    /* ==================== 数据源网格（两列布局） ==================== */
    .datasource-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
    }

    .datasource-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        padding: 20px 16px;
        background: white;
        border: 1px solid #E0E0E0;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.2s;
    }

    .datasource-card:active {
        background: #F5F5F5;
        transform: scale(0.98);
        border-color: #2D3E5F;
    }

    .datasource-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #F5F5F5;
        flex-shrink: 0;
    }

    .favicon-img {
        width: 32px;
        height: 32px;
        object-fit: contain;
    }

    .favicon-placeholder {
        font-size: 24px;
        font-weight: 600;
        color: #2D3E5F;
    }

    .datasource-info {
        text-align: center;
    }

    .datasource-name {
        font-size: 15px;
        font-weight: 600;
        color: #2C2C2C;
    }

    /* ==================== 空状态 ==================== */
    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 60px 24px;
        text-align: center;
    }

    .empty-icon {
        font-size: 64px;
        opacity: 0.5;
        margin-bottom: 16px;
    }

    .empty-text {
        font-size: 16px;
        color: #2C2C2C;
        margin: 0 0 8px 0;
    }

    .empty-hint {
        font-size: 14px;
        color: #757575;
        margin: 0;
    }

    /* ==================== 状态容器 ==================== */
    .status-container {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 300px;
    }

    .syncing-wrapper,
    .success-wrapper,
    .error-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 24px;
    }

    .syncing-spinner {
        font-size: 48px;
        animation: spin 1s linear infinite;
        margin-bottom: 16px;
    }

    @@keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    .success-icon {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: #4CAF50;
        color: white;
        font-size: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 16px;
    }

    .error-icon {
        font-size: 48px;
        margin-bottom: 16px;
    }

    .status-title {
        font-size: 20px;
        font-weight: 600;
        color: #2C2C2C;
        margin: 0 0 8px 0;
    }

    .status-desc {
        font-size: 15px;
        color: #757575;
        margin: 0 0 16px 0;
    }

    .retry-btn {
        padding: 12px 24px;
        background: #2D3E5F;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 15px;
        cursor: pointer;
    }

    /* ==================== Windows/桌面适配 ==================== */
    @@media (min-width: 768px) {
        .sync-page {
            max-width: 600px;
            margin: 0 auto;
        }

        .datasource-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }
</style>

@code {
    private SyncStep currentStep = SyncStep.SelectDataSource;
    private List<DataSourceConfig> registeredSources = new();
    private bool isSyncing = false;
    private bool syncSuccess = false;
    private string syncError = string.Empty;
    private int syncedCourseCount = 0;

    protected override void OnInitialized()
    {
        // 获取所有已注册的数据源
        registeredSources = DataCaptureService.GetRegisteredSources();
    }

    private async void SelectDataSource(string sourceId)
    {
        currentStep = SyncStep.Syncing;
        isSyncing = true;
        syncSuccess = false;
        syncError = string.Empty;
        syncedCourseCount = 0;
        StateHasChanged();

        // 启动数据抓取
        DataCaptureService.StartCapture(sourceId, async (result) =>
        {
            isSyncing = false;

            if (result.Success && !string.IsNullOrEmpty(result.JsonData))
            {
                // 解析并保存数据到数据库
                syncedCourseCount = await SaveCourseDataAsync(result.JsonData, sourceId);
                syncSuccess = true;
            }
            else
            {
                syncError = result.Error ?? "未知错误";
            }

            StateHasChanged();
        });
    }

    private async Task<int> SaveCourseDataAsync(string jsonData, string sourceId)
    {
        try
        {
            var options = new JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            };

            // 根据同济大学的 API 响应格式解析
            var jsonDoc = JsonDocument.Parse(jsonData);
            var root = jsonDoc.RootElement;

            List<CourseSchedule> courses = new();

            // 尝试解析同济大学课表 API 响应格式
            if (root.TryGetProperty("data", out var data))
            {
                // 同济 API 返回格式: { "data": [ { "kcmc": "高等数学", ... } ] }
                foreach (var item in data.EnumerateArray())
                {
                    var dayOfWeek = GetDayOfWeekProp(item) ?? GetIntProp(item, "xqj") ?? GetIntProp(item, "dayOfWeek") ?? 1;
                    var (startPeriod, endPeriod) = GetPeriodRange(item);

                    var course = new CourseSchedule
                    {
                        CourseName = GetStringProp(item, "kcmc") ?? GetStringProp(item, "courseName") ?? "",
                        Location = GetStringProp(item, "cdmc") ?? GetStringProp(item, "location") ?? "",
                        Teacher = GetStringProp(item, "jsxm") ?? GetStringProp(item, "teacher") ?? "",
                        DayOfWeek = dayOfWeek,
                        StartPeriod = Math.Clamp(startPeriod, 1, 14),
                        EndPeriod = Math.Clamp(endPeriod, 1, 14),
                        StartWeek = GetIntProp(item, "kkz") ?? GetIntProp(item, "startWeek") ?? GetIntProp(item, "startZc") ?? 1,
                        EndWeek = GetIntProp(item, "jkz") ?? GetIntProp(item, "endWeek") ?? GetIntProp(item, "endZc") ?? 16,
                        WeekType = GetStringProp(item, "zcmc") ?? GetStringProp(item, "weekType"),
                        Semester = GetStringProp(item, "xnxqmc") ?? GetStringProp(item, "semester") ?? GetCurrentSemester()
                    };

                    if (course.EndPeriod < course.StartPeriod)
                    {
                        course.EndPeriod = course.StartPeriod;
                    }

                    if (course.EndWeek < course.StartWeek)
                    {
                        course.EndWeek = course.StartWeek;
                    }

                    if (!string.IsNullOrEmpty(course.CourseName))
                    {
                        courses.Add(course);
                    }
                }
            }

            if (courses.Count == 0)
            {
                Debug.WriteLine("[Sync] 未能解析出任何课程数据");
                return 0;
            }

            NormalizeImportedDayOfWeek(courses);

            // 保存到数据库
            var dbContext = new AppDbContext();

            // 清除该学期的旧数据
            var semester = courses.First().Semester;
            var oldCourses = await dbContext.CourseSchedules
                .Where(c => c.Semester == semester)
                .ToListAsync();

            dbContext.CourseSchedules.RemoveRange(oldCourses);

            // 添加新数据
            dbContext.CourseSchedules.AddRange(courses);
            await dbContext.SaveChangesAsync();

            Debug.WriteLine($"[Sync] 成功保存 {courses.Count} 门课程到数据库");
            return courses.Count;
        }
        catch (Exception ex)
        {
            Debug.WriteLine($"[Sync] 保存数据失败: {ex.Message}");
            return 0;
        }
    }

    private static string? GetStringProp(JsonElement element, string name)
    {
        if (element.TryGetProperty(name, out var prop))
        {
            return prop.ValueKind == JsonValueKind.String ? prop.GetString() : prop.ToString();
        }
        return null;
    }

    private static int? GetIntProp(JsonElement element, string name)
    {
        if (!element.TryGetProperty(name, out var prop))
        {
            return null;
        }

        if (prop.ValueKind == JsonValueKind.Number)
        {
            return prop.GetInt32();
        }

        if (prop.ValueKind == JsonValueKind.String)
        {
            var raw = prop.GetString();
            if (string.IsNullOrWhiteSpace(raw))
            {
                return null;
            }

            if (int.TryParse(raw, out var value))
            {
                return value;
            }

            var digits = new string(raw.Where(char.IsDigit).ToArray());
            if (int.TryParse(digits, out value))
            {
                return value;
            }
        }

        return null;
    }

    private static int NormalizeDayOfWeek(int dayOfWeek)
    {
        return Math.Clamp(dayOfWeek, 1, 7);
    }

    private static void NormalizeImportedDayOfWeek(List<CourseSchedule> courses)
    {
        var days = courses.Select(c => c.DayOfWeek).ToList();
        if (days.Count == 0)
        {
            return;
        }

        // 某些接口返回 0-6（周一=0），统一转换为 1-7。
        var looksZeroBased = days.All(d => d >= 0 && d <= 6) && days.Contains(0) && !days.Contains(7);
        if (looksZeroBased)
        {
            foreach (var course in courses)
            {
                course.DayOfWeek += 1;
            }
        }

        foreach (var course in courses)
        {
            course.DayOfWeek = NormalizeDayOfWeek(course.DayOfWeek);
        }
    }

    private static int? GetDayOfWeekProp(JsonElement element)
    {
        var dayText = GetStringProp(element, "xqmc")
            ?? GetStringProp(element, "weekday")
            ?? GetStringProp(element, "dayName");

        if (string.IsNullOrWhiteSpace(dayText))
        {
            return null;
        }

        if (dayText.Contains("一")) return 1;
        if (dayText.Contains("二")) return 2;
        if (dayText.Contains("三")) return 3;
        if (dayText.Contains("四")) return 4;
        if (dayText.Contains("五")) return 5;
        if (dayText.Contains("六")) return 6;
        if (dayText.Contains("日") || dayText.Contains("天")) return 7;

        if (int.TryParse(new string(dayText.Where(char.IsDigit).ToArray()), out var dayNum))
        {
            return NormalizeDayOfWeek(dayNum);
        }

        return null;
    }

    private static (int StartPeriod, int EndPeriod) GetPeriodRange(JsonElement element)
    {
        var start = GetIntProp(element, "kcsj")
            ?? GetIntProp(element, "startPeriod")
            ?? GetIntProp(element, "beginSection");

        var end = GetIntProp(element, "jcsj")
            ?? GetIntProp(element, "endPeriod")
            ?? GetIntProp(element, "endSection");

        if (start.HasValue && end.HasValue)
        {
            return (start.Value, end.Value);
        }

        var sectionText = GetStringProp(element, "section")
            ?? GetStringProp(element, "jcdm")
            ?? GetStringProp(element, "timeNode");

        if (!string.IsNullOrWhiteSpace(sectionText))
        {
            var normalized = sectionText.Replace("节", "").Replace("[", "").Replace("]", "");
            var parts = normalized.Split('-', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            if (parts.Length == 2 && int.TryParse(parts[0], out var s) && int.TryParse(parts[1], out var e))
            {
                return (s, e);
            }

            if (int.TryParse(new string(normalized.Where(char.IsDigit).ToArray()), out var single))
            {
                return (single, single);
            }
        }

        return (1, 2);
    }

    private static string GetCurrentSemester()
    {
        var now = DateTime.Now;
        var year = now.Year;
        if (now.Month >= 9)
        {
            return $"{year}-{year + 1}-1"; // 第一学期
        }
        else if (now.Month >= 2)
        {
            return $"{year - 1}-{year}-2"; // 第二学期
        }
        else
        {
            return $"{year - 1}-{year}-1"; // 第一学期
        }
    }

    private void NavigateBack()
    {
        Navigation.NavigateTo("/chat");
    }

    private void GoBack()
    {
        currentStep = SyncStep.SelectDataSource;
        isSyncing = false;
        syncSuccess = false;
        syncError = string.Empty;
        syncedCourseCount = 0;
        StateHasChanged();
    }
}

@code {
    enum SyncStep
    {
        SelectDataSource,
        Syncing
    }
}
