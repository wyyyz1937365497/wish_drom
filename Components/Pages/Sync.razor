@page "/sync"
@using wish_drom.Components.Shared
@using wish_drom.Services.Interfaces
@inject IDataCaptureService DataCaptureService
@inject NavigationManager Navigation

<div class="sync-container">
    <h1>🔄 数据同步</h1>
    <p class="subtitle">从教务系统同步课程和活动数据</p>

    @if (!isSyncing)
    {
        <div class="sync-options">
            <div class="sync-card">
                <div class="card-icon">📚</div>
                <h3>同步课程表</h3>
                <p>从教务系统导入课程安排</p>
                <button class="btn-primary" @onclick="StartScheduleSync">开始同步</button>
            </div>

            <div class="sync-card">
                <div class="card-icon">🎉</div>
                <h3>同步活动</h3>
                <p>获取最新校园活动信息</p>
                <button class="btn-secondary" @onclick="StartActivitySync">开始同步</button>
            </div>
        </div>

        <div class="help-section">
            <h2>使用说明</h2>
            <ol>
                <li>点击"开始同步"按钮</li>
                <li>在弹出的 WebView 中登录教务系统</li>
                <li>导航到课表/活动页面</li>
                <li>点击"完成抓取"按钮</li>
                <li>等待数据解析和保存完成</li>
            </ol>

            <div class="privacy-notice">
                <h3>🔒 隐私保护</h3>
                <ul>
                    <li>所有数据仅存储在您的设备本地</li>
                    <li>同步完成后自动清除登录 Cookie</li>
                    <li>不会上传任何个人信息到远程服务器</li>
                </ul>
            </div>
        </div>
    }
    else
    {
        <div class="syncing-state">
            <LoadingSpinner Message="@syncProgress" />

            @if (syncResults.Any())
            {
                <div class="sync-results">
                    <h3>同步结果</h3>
                    @foreach (var result in syncResults)
                    {
                        <div class="result-item @result.Type">
                            <span class="result-icon">@result.Icon</span>
                            <span class="result-text">@result.Message</span>
                        </div>
                    }
                </div>
            }

            <button class="btn-secondary" @onclick="BackToHome">返回首页</button>
        </div>
    }
</div>

<style>
    .sync-container {
        max-width: 600px;
        margin: 0 auto;
        padding: 20px;
        background-color: #f5f5f5;
        min-height: 100vh;
    }

    .sync-container h1 {
        color: #512BD4;
        text-align: center;
        margin-bottom: 8px;
    }

    .subtitle {
        text-align: center;
        color: #666;
        margin-bottom: 24px;
    }

    .sync-options {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 16px;
        margin-bottom: 32px;
    }

    .sync-card {
        background: white;
        padding: 24px;
        border-radius: 12px;
        text-align: center;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        transition: transform 0.2s;
    }

    .sync-card:hover {
        transform: translateY(-2px);
    }

    .card-icon {
        font-size: 48px;
        margin-bottom: 12px;
    }

    .sync-card h3 {
        color: #333;
        margin-bottom: 8px;
    }

    .sync-card p {
        color: #666;
        font-size: 14px;
        margin-bottom: 16px;
    }

    .btn-primary, .btn-secondary {
        padding: 12px 24px;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 500;
        font-size: 14px;
    }

    .btn-primary {
        background-color: #512BD4;
        color: white;
    }

    .btn-secondary {
        background-color: #6c757d;
        color: white;
    }

    .help-section {
        background: white;
        padding: 20px;
        border-radius: 12px;
        margin-bottom: 16px;
    }

    .help-section h2 {
        font-size: 18px;
        color: #333;
        margin-bottom: 16px;
    }

    .help-section ol {
        padding-left: 20px;
        color: #555;
        line-height: 1.8;
    }

    .help-section li {
        margin-bottom: 8px;
    }

    .privacy-notice {
        background-color: #f8f9fa;
        padding: 16px;
        border-radius: 8px;
        margin-top: 20px;
    }

    .privacy-notice h3 {
        font-size: 16px;
        color: #512BD4;
        margin-bottom: 12px;
    }

    .privacy-notice ul {
        padding-left: 20px;
        color: #666;
        font-size: 14px;
    }

    .syncing-state {
        text-align: center;
    }

    .sync-results {
        background: white;
        padding: 16px;
        border-radius: 12px;
        margin: 20px auto;
        max-width: 400px;
        text-align: left;
    }

    .sync-results h3 {
        font-size: 16px;
        color: #333;
        margin-bottom: 12px;
    }

    .result-item {
        display: flex;
        align-items: center;
        padding: 8px;
        border-radius: 6px;
        margin-bottom: 8px;
    }

    .result-item.success {
        background-color: #d4edda;
    }

    .result-item.error {
        background-color: #f8d7da;
    }

    .result-item.info {
        background-color: #d1ecf1;
    }

    .result-icon {
        font-size: 20px;
        margin-right: 12px;
    }

    .result-text {
        flex: 1;
        color: #333;
    }
</style>

@code {
    private bool isSyncing = false;
    private string syncProgress = "准备中...";
    private List<SyncResult> syncResults = new();

    private class SyncResult
    {
        public string Type { get; set; } = "info"; // success, error, info
        public string Icon { get; set; } = "ℹ️";
        public string Message { get; set; } = string.Empty;
    }

    private async Task StartScheduleSync()
    {
        await StartSyncAsync(async ct =>
        {
            syncResults.Clear();
            syncResults.Add(new SyncResult { Type = "info", Icon = "📚", Message = "开始同步课程表..." });

            // 这里使用示例URL，实际使用时需要替换
            var targetUrl = "https://your-educational-system-url/schedule";

            DataCaptureService.CaptureProgress += OnCaptureProgress;

            try
            {
                var count = await DataCaptureService.CaptureScheduleDataAsync(targetUrl, ct);
                syncResults.Add(new SyncResult { Type = "success", Icon = "✅", Message = $"成功同步 {count} 条课程数据" });
            }
            catch (Exception ex)
            {
                syncResults.Add(new SyncResult { Type = "error", Icon = "❌", Message = $"同步失败: {ex.Message}" });
            }
            finally
            {
                DataCaptureService.CaptureProgress -= OnCaptureProgress;
            }
        });
    }

    private async Task StartActivitySync()
    {
        await StartSyncAsync(async ct =>
        {
            syncResults.Clear();
            syncResults.Add(new SyncResult { Type = "info", Icon = "🎉", Message = "开始同步活动..." });

            var targetUrl = "https://your-activity-url";

            DataCaptureService.CaptureProgress += OnCaptureProgress;

            try
            {
                var count = await DataCaptureService.CaptureActivityDataAsync(targetUrl, ct);
                syncResults.Add(new SyncResult { Type = "success", Icon = "✅", Message = $"成功同步 {count} 条活动数据" });
            }
            catch (Exception ex)
            {
                syncResults.Add(new SyncResult { Type = "error", Icon = "❌", Message = $"同步失败: {ex.Message}" });
            }
            finally
            {
                DataCaptureService.CaptureProgress -= OnCaptureProgress;
            }
        });
    }

    private async Task StartSyncAsync(Func<CancellationToken, Task> syncAction)
    {
        isSyncing = true;
        syncProgress = "正在启动...";
        StateHasChanged();

        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromMinutes(5));
            await syncAction(cts.Token);
            syncProgress = "同步完成";
        }
        catch (Exception ex)
        {
            syncProgress = $"发生错误: {ex.Message}";
            syncResults.Add(new SyncResult { Type = "error", Icon = "❌", Message = ex.Message });
        }
        finally
        {
            isSyncing = false;
            StateHasChanged();
        }
    }

    private void OnCaptureProgress(object? sender, string message)
    {
        syncProgress = message;
        InvokeAsync(StateHasChanged);
    }

    private void BackToHome()
    {
        Navigation.NavigateTo("/");
    }
}
