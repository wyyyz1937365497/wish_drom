@page "/sync"
@using wish_drom.Models
@using wish_drom.Services.Interfaces
@using System.Diagnostics
@inject IDataCaptureService DataCaptureService
@inject NavigationManager Navigation

<div class="sync-page">
    @* 顶部应用栏 *@
    <header class="app-bar">
        <button class="back-btn" @onclick="@(() => NavigateBack())">
            <span class="back-icon">←</span>
        </button>
        <h1 class="app-title">数据同步</h1>
        <div class="app-bar-spacer"></div>
    </header>

    @* 内容区域 *@
    <div class="sync-content">
        @if (currentStep == SyncStep.SelectDataSource)
        {
            @* 数据源选择 - 两列网格布局 *@
            <section class="section">
                <h2 class="section-title">选择数据源</h2>
                <p class="section-desc">点击下方按钮，在 WebView 中登录并提取数据</p>

                @if (registeredSources.Any())
                {
                    <div class="datasource-grid">
                        @foreach (var source in registeredSources)
                        {
                            <button class="datasource-card" @onclick="@(() => SelectDataSource(source.Id))">
                                <div class="datasource-icon">
                                    @if (!string.IsNullOrEmpty(source.FaviconUrl))
                                    {
                                        <img src="@source.FaviconUrl" class="favicon-img" alt="@source.DisplayName" />
                                    }
                                    else
                                    {
                                        <span class="favicon-placeholder">@source.GetFaviconLetter()</span>
                                    }
                                </div>
                                <div class="datasource-info">
                                    <span class="datasource-name">@source.DisplayName</span>
                                </div>
                            </button>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <span class="empty-icon">📭</span>
                        <p class="empty-text">暂无已注册的数据源</p>
                        <p class="empty-hint">请联系管理员添加数据提供者</p>
                    </div>
                }
            </section>
        }
        else if (currentStep == SyncStep.Syncing)
        {
            @* 同步状态提示 *@
            <section class="section">
                <div class="status-container">
                    @if (isSyncing)
                    {
                        <div class="syncing-wrapper">
                            <div class="syncing-spinner">⟳</div>
                            <h3 class="status-title">正在同步</h3>
                            <p class="status-desc">请在 WebView 中完成操作</p>
                        </div>
                    }
                    else if (syncSuccess)
                    {
                        <div class="success-wrapper">
                            <div class="success-icon">✓</div>
                            <h3 class="status-title">同步成功</h3>
                            <p class="status-desc">数据已成功提取并保存</p>
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(syncError))
                    {
                        <div class="error-wrapper">
                            <div class="error-icon">⚠️</div>
                            <h3 class="status-title">同步失败</h3>
                            <p class="status-desc">@syncError</p>
                            <button class="retry-btn" @onclick="@(() => GoBack())">返回重试</button>
                        </div>
                    }
                </div>
            </section>
        }
    </div>
</div>

<style>
    /* ==================== 主容器 ==================== */
    .sync-page {
        display: flex;
        flex-direction: column;
        height: 100%;
        background-color: #F5F5F5;
    }

    /* ==================== 应用栏 ==================== */
    .app-bar {
        display: flex;
        align-items: center;
        padding: 12px 16px;
        padding-top: max(12px, env(safe-area-inset-top));
        background-color: #2D3E5F;
        color: white;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        z-index: 10;
    }

    .back-btn {
        width: 40px;
        height: 40px;
        border: none;
        background: none;
        color: white;
        font-size: 24px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-right: 8px;
    }

    .app-title {
        font-size: 20px;
        font-weight: 600;
        margin: 0;
        flex: 1;
    }

    .app-bar-spacer {
        width: 40px;
    }

    /* ==================== 内容区域 ==================== */
    .sync-content {
        flex: 1;
        overflow-y: auto;
        -webkit-overflow-scrolling: touch;
        padding: 16px;
    }

    .section {
        margin-bottom: 24px;
    }

    .section-title {
        font-size: 22px;
        font-weight: 600;
        color: #2C2C2C;
        margin: 0 0 8px 0;
    }

    .section-desc {
        font-size: 14px;
        color: #757575;
        margin: 0 0 20px 0;
    }

    /* ==================== 数据源网格（两列布局） ==================== */
    .datasource-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
    }

    .datasource-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        padding: 20px 16px;
        background: white;
        border: 1px solid #E0E0E0;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.2s;
    }

    .datasource-card:active {
        background: #F5F5F5;
        transform: scale(0.98);
        border-color: #2D3E5F;
    }

    .datasource-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #F5F5F5;
        flex-shrink: 0;
    }

    .favicon-img {
        width: 32px;
        height: 32px;
        object-fit: contain;
    }

    .favicon-placeholder {
        font-size: 24px;
        font-weight: 600;
        color: #2D3E5F;
    }

    .datasource-info {
        text-align: center;
    }

    .datasource-name {
        font-size: 15px;
        font-weight: 600;
        color: #2C2C2C;
    }

    /* ==================== 空状态 ==================== */
    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 60px 24px;
        text-align: center;
    }

    .empty-icon {
        font-size: 64px;
        opacity: 0.5;
        margin-bottom: 16px;
    }

    .empty-text {
        font-size: 16px;
        color: #2C2C2C;
        margin: 0 0 8px 0;
    }

    .empty-hint {
        font-size: 14px;
        color: #757575;
        margin: 0;
    }

    /* ==================== 状态容器 ==================== */
    .status-container {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 300px;
    }

    .syncing-wrapper,
    .success-wrapper,
    .error-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 24px;
    }

    .syncing-spinner {
        font-size: 48px;
        animation: spin 1s linear infinite;
        margin-bottom: 16px;
    }

    @@keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }

    .success-icon {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: #4CAF50;
        color: white;
        font-size: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 16px;
    }

    .error-icon {
        font-size: 48px;
        margin-bottom: 16px;
    }

    .status-title {
        font-size: 20px;
        font-weight: 600;
        color: #2C2C2C;
        margin: 0 0 8px 0;
    }

    .status-desc {
        font-size: 15px;
        color: #757575;
        margin: 0 0 16px 0;
    }

    .retry-btn {
        padding: 12px 24px;
        background: #2D3E5F;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 15px;
        cursor: pointer;
    }

    /* ==================== Windows/桌面适配 ==================== */
    @@media (min-width: 768px) {
        .sync-page {
            max-width: 600px;
            margin: 0 auto;
        }

        .datasource-grid {
            grid-template-columns: repeat(3, 1fr);
        }
    }
</style>

@code {
    private SyncStep currentStep = SyncStep.SelectDataSource;
    private List<DataSourceConfig> registeredSources = new();
    private bool isSyncing = false;
    private bool syncSuccess = false;
    private string syncError = string.Empty;

    protected override void OnInitialized()
    {
        // 获取所有已注册的数据源
        registeredSources = DataCaptureService.GetRegisteredSources();
    }

    private void SelectDataSource(string sourceId)
    {
        currentStep = SyncStep.Syncing;
        isSyncing = true;
        syncSuccess = false;
        syncError = string.Empty;
        StateHasChanged();

        // 启动数据抓取
        DataCaptureService.StartCapture(sourceId, (result) =>
        {
            isSyncing = false;

            if (result.Success)
            {
                syncSuccess = true;
                // TODO: 保存 JSON 数据到数据库
                Debug.WriteLine($"[Sync] 获取到数据: {result.JsonData?.Length ?? 0} 字符");
            }
            else
            {
                syncError = result.Error ?? "未知错误";
            }

            StateHasChanged();
        });
    }

    private void NavigateBack()
    {
        Navigation.NavigateTo("/chat");
    }

    private void GoBack()
    {
        currentStep = SyncStep.SelectDataSource;
        isSyncing = false;
        syncSuccess = false;
        syncError = string.Empty;
        StateHasChanged();
    }
}

@code {
    enum SyncStep
    {
        SelectDataSource,
        Syncing
    }
}
