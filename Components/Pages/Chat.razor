@page "/chat"
@using wish_drom.Models
@using wish_drom.Services
@inject IChatService ChatService
@inject NavigationManager Navigation
@inject IJSRuntime JavaScriptRuntime

<div class="chat-page">
    @* 顶部应用栏 *@
    <header class="chat-header">
        <div class="header-content">
            <div class="assistant-info">
                <div class="avatar-large">🎓</div>
                <div class="info-text">
                    <h1 class="header-title">智能校园助手</h1>
                    <p class="header-status">@(isConfigured ? "在线" : "未配置")</p>
                </div>
            </div>
            <div class="header-actions">
                @if (messages.Count > 0)
                {
                    <button class="icon-btn" @onclick="@(() => StartNewChat())" title="新建对话">
                        <span>✏️</span>
                    </button>
                }
                <button class="icon-btn" @onclick="@(() => ShowHistory())" title="历史对话">
                    <span>📋</span>
                </button>
            </div>
        </div>
    </header>

    @* 消息列表区域 *@
    <div class="messages-container" id="messagesContainer">
        @if (messages.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-icon">💬</div>
                <h2 class="empty-title">开始对话</h2>
                <p class="empty-desc">我是你的智能校园助手，可以帮你：</p>

                <div class="suggestion-chips">
                    <button class="chip" @onclick="@(() => SendSuggestion("今天有什么课？"))">今天有什么课？</button>
                    <button class="chip" @onclick="@(() => SendSuggestion("本周活动"))">本周活动</button>
                    <button class="chip" @onclick="@(() => SendSuggestion("学习建议"))">学习建议</button>
                </div>

                @if (!isConfigured)
                {
                    <div class="config-card">
                        <span class="config-icon">⚠️</span>
                        <p class="config-text">请先配置 API Key</p>
                        <button class="config-btn" @onclick="@(() => NavigateToSettings())">去设置</button>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="messages-list">
                @foreach (var message in messages)
                {
                    <div class="message-wrapper @message.Role">
                        @if (message.Role == "user")
                        {
                            <div class="message-bubble user-message">
                                <p class="message-text">@message.Content</p>
                                <span class="message-time">@message.Timestamp.ToString("HH:mm")</span>
                            </div>
                        }
                        else
                        {
                            <div class="message-bubble assistant-message">
                                <div class="message-text markdown-body">@((MarkupString)RenderMarkdown(message.Content))</div>
                                <span class="message-time">@message.Timestamp.ToString("HH:mm")</span>
                            </div>
                        }
                    </div>
                }

                @if (isStreaming)
                {
                    <div class="message-wrapper assistant">
                        <div class="message-bubble assistant-message streaming">
                            <p class="message-text">@streamingContent</p>
                            <div class="typing-dots">
                                <span></span>
                                <span></span>
                                <span></span>
                            </div>
                        </div>
                    </div>
                }
            </div>

            @* 底部垫高，为输入框留出空间 *@
            <div class="messages-spacer"></div>
        }
    </div>

    @* 输入区域 *@
    <div class="input-container">
        @if (isConfigured)
        {
            <div class="input-wrapper">
                <input type="text"
                       class="message-input"
                       placeholder="输入消息..."
                       @bind="inputText"
                       @bind:event="oninput"
                       @onkeypress="@((e) => HandleKeyPress(e))"
                       @onfocus="@(() => InputFocused())"
                       @onblur="@(() => InputBlurred())"
                       disabled="@isStreaming">
                <button class="send-btn" @onclick="@(() => SendMessage())" disabled="@(isStreaming || string.IsNullOrEmpty(inputText))">
                    <span class="send-icon">@(isStreaming ? "⏳" : "➤")</span>
                </button>
            </div>
        }
        else
        {
            <button class="setup-banner" @onclick="@(() => NavigateToSettings())">
                <span class="banner-icon">⚙️</span>
                <span class="banner-text">点击配置 API Key</span>
                <span class="banner-arrow">➤</span>
            </button>
        }
    </div>
</div>

<style>
    /* ==================== 主容器 ==================== */
    .chat-page {
        display: flex;
        flex-direction: column;
        height: 100%;
        background-color: #F5F5F5;
    }

    /* ==================== 顶部应用栏 ==================== */
    .chat-header {
        background-color: #2D3E5F;
        color: white;
        padding: 12px 16px;
        padding-top: max(12px, env(safe-area-inset-top));
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        z-index: 10;
    }

    .header-content {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .assistant-info {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .avatar-large {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: linear-gradient(135deg, #8B3A3A 0%, #6B2B2B 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.2);
    }

    .info-text {
        flex: 1;
    }

    .header-title {
        font-size: 18px;
        font-weight: 600;
        margin: 0;
        line-height: 1.3;
    }

    .header-status {
        font-size: 13px;
        margin: 0;
        opacity: 0.8;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .header-status::before {
        content: '';
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background-color: #4CAF50;
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }

    .icon-btn {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        border: none;
        background: rgba(255,255,255,0.1);
        color: white;
        font-size: 18px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s;
    }

    .icon-btn:active {
        background: rgba(255,255,255,0.2);
    }

    .header-actions {
        display: flex;
        gap: 8px;
    }

    /* ==================== 消息区域 ==================== */
    .messages-container {
        flex: 1;
        overflow-y: auto;
        -webkit-overflow-scrolling: touch;
    }

    .messages-container::-webkit-scrollbar {
        width: 4px;
    }

    .messages-container::-webkit-scrollbar-thumb {
        background: rgba(0,0,0,0.2);
        border-radius: 2px;
    }

    /* ==================== 空状态 ==================== */
    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 40px 24px;
        min-height: 100%;
        text-align: center;
    }

    .empty-icon {
        font-size: 64px;
        margin-bottom: 16px;
        opacity: 0.6;
    }

    .empty-title {
        font-size: 22px;
        font-weight: 600;
        color: #2D3E5F;
        margin: 0 0 8px 0;
    }

    .empty-desc {
        font-size: 15px;
        color: #757575;
        margin: 0 0 24px 0;
    }

    .suggestion-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        justify-content: center;
        margin-bottom: 24px;
    }

    .chip {
        padding: 10px 16px;
        background: white;
        border: 1px solid #E0E0E0;
        border-radius: 20px;
        font-size: 14px;
        color: #2D3E5F;
        cursor: pointer;
        transition: all 0.2s;
    }

    .chip:active {
        background: #F0F0F0;
        transform: scale(0.98);
    }

    .config-card {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 16px;
        background: #FFF3E0;
        border-radius: 12px;
        border: 1px solid #FFE0B2;
    }

    .config-icon {
        font-size: 24px;
    }

    .config-text {
        flex: 1;
        font-size: 14px;
        color: #E65100;
        margin: 0;
        text-align: left;
    }

    .config-btn {
        padding: 8px 16px;
        background: #FF9800;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
    }

    /* ==================== 消息列表 ==================== */
    .messages-list {
        padding: 16px;
    }

    .messages-spacer {
        height: 16px;
    }

    .message-wrapper {
        display: flex;
        margin-bottom: 16px;
        animation: messageIn 0.3s ease-out;
    }

    .message-wrapper.user {
        justify-content: flex-end;
    }

    @@keyframes messageIn {
        from {
            opacity: 0;
            transform: translateY(8px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .message-bubble {
        max-width: 75%;
        padding: 12px 16px;
        position: relative;
    }

    .user-message {
        background: linear-gradient(135deg, #2D3E5F 0%, #1A2744 100%);
        color: white;
        border-radius: 20px 20px 4px 20px;
    }

    .assistant-message {
        background: white;
        color: #2C2C2C;
        border-radius: 20px 20px 20px 4px;
        box-shadow: 0 1px 2px rgba(0,0,0,0.1);
    }

    .assistant-message.streaming {
        background: linear-gradient(to bottom, #FFFFFF 0%, #FAFAFA 100%);
    }

    .message-text {
        font-size: 15px;
        line-height: 1.5;
        margin: 0 0 4px 0;
        word-wrap: break-word;
        white-space: pre-wrap;
    }

    .message-text :deep(strong) {
        font-weight: 600;
    }

    .message-text :deep(em) {
        font-style: italic;
        opacity: 0.8;
    }

    .message-time {
        font-size: 11px;
        opacity: 0.6;
    }

    /* ==================== 输入指示器 ==================== */
    .typing-dots {
        display: inline-flex;
        gap: 4px;
        margin-left: 8px;
    }

    .typing-dots span {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #2D3E5F;
        animation: bounce 1.4s infinite;
    }

    .typing-dots span:nth-child(2) {
        animation-delay: 0.2s;
    }

    .typing-dots span:nth-child(3) {
        animation-delay: 0.4s;
    }

    @@keyframes bounce {
        0%, 60%, 100% { transform: translateY(0); }
        30% { transform: translateY(-6px); }
    }

    /* ==================== 输入区域 ==================== */
    .input-container {
        background: white;
        border-top: 1px solid #E0E0E0;
        padding: 12px 16px;
        padding-bottom: max(12px, env(safe-area-inset-bottom));
    }

    .input-wrapper {
        display: flex;
        gap: 8px;
        align-items: flex-end;
    }

    .message-input {
        flex: 1;
        padding: 12px 16px;
        background: #F5F5F5;
        border: none;
        border-radius: 24px;
        font-size: 16px;
        color: #2C2C2C;
        outline: none;
        max-height: 120px;
        resize: none;
    }

    .message-input::placeholder {
        color: #9E9E9E;
    }

    .message-input:focus {
        background: #EEEEEE;
    }

    .send-btn {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        border: none;
        background: linear-gradient(135deg, #8B3A3A 0%, #6B2B2B 100%);
        color: white;
        font-size: 20px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: transform 0.2s;
    }

    .send-btn:active {
        transform: scale(0.95);
    }

    .send-btn:disabled {
        opacity: 0.5;
    }

    /* ==================== 设置横幅 ==================== */
    .setup-banner {
        width: 100%;
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 20px;
        background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
        border: 1px solid #FFB74D;
        border-radius: 12px;
        color: #E65100;
        font-size: 15px;
        font-weight: 500;
        cursor: pointer;
        transition: transform 0.2s;
    }

    .setup-banner:active {
        transform: scale(0.98);
    }

    .banner-icon {
        font-size: 20px;
    }

    .banner-text {
        flex: 1;
    }

    .banner-arrow {
        font-size: 18px;
    }

    /* ==================== Markdown 样式 ==================== */
    .markdown-body {
        line-height: 1.6;
    }

    .markdown-body :deep(p) {
        margin: 0.5em 0;
    }

    .markdown-body :deep(code) {
        background: #f4f4f4;
        padding: 2px 6px;
        border-radius: 4px;
        font-family: 'Consolas', 'Monaco', monospace;
        font-size: 0.9em;
    }

    .markdown-body :deep(pre) {
        background: #2d2d2d;
        color: #f8f8f2;
        padding: 16px;
        border-radius: 8px;
        overflow-x: auto;
        margin: 8px 0;
    }

    .markdown-body :deep(pre code) {
        background: transparent;
        padding: 0;
        color: inherit;
    }

    .markdown-body :deep(ul), .markdown-body :deep(ol) {
        margin: 0.5em 0;
        padding-left: 1.5em;
    }

    .markdown-body :deep(li) {
        margin: 0.25em 0;
    }

    .markdown-body :deep(blockquote) {
        border-left: 4px solid #ddd;
        margin: 0.5em 0;
        padding-left: 16px;
        color: #666;
    }

    .markdown-body :deep(a) {
        color: #8B3A3A;
        text-decoration: underline;
    }

    .markdown-body :deep(table) {
        border-collapse: collapse;
        width: 100%;
        margin: 8px 0;
    }

    .markdown-body :deep(th), .markdown-body :deep(td) {
        border: 1px solid #ddd;
        padding: 8px;
        text-align: left;
    }

    .markdown-body :deep(th) {
        background: #f4f4f4;
        font-weight: 600;
    }

    /* ==================== Windows/桌面适配 ==================== */
    @@media (min-width: 768px) {
        .chat-page {
            max-width: 480px;
            margin: 0 auto;
            box-shadow: 0 0 40px rgba(0,0,0,0.1);
        }

        .message-bubble {
            max-width: 65%;
        }
    }
</style>

@code {
    private List<ChatMessage> messages = new();
    private string inputText = string.Empty;
    private bool isStreaming = false;
    private bool isConfigured = false;
    private string streamingContent = string.Empty;
    private string currentSessionId = string.Empty;

    private string CurrentSessionId
    {
        get => Preferences.Default.Get("current_chat_session", "");
        set => Preferences.Default.Set("current_chat_session", value);
    }

    protected override async Task OnInitializedAsync()
    {
        isConfigured = await ChatService.IsConfiguredAsync();

        if (isConfigured)
        {
            var savedSessionId = CurrentSessionId;
            if (!string.IsNullOrEmpty(savedSessionId))
            {
                var history = await ChatService.GetSessionHistoryAsync(savedSessionId);
                if (history.Count > 0)
                {
                    currentSessionId = savedSessionId;
                    messages = history.Select(h => new ChatMessage
                    {
                        Role = h.Role,
                        Content = h.Content,
                        Timestamp = DateTime.Now
                    }).ToList();
                }
                else
                {
                    currentSessionId = ChatService.StartNewSession();
                    CurrentSessionId = currentSessionId;
                }
            }
            else
            {
                currentSessionId = ChatService.StartNewSession();
                CurrentSessionId = currentSessionId;
            }
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(inputText) || isStreaming)
            return;

        var userMessage = inputText.Trim();
        inputText = string.Empty;

        messages.Add(new ChatMessage
        {
            Role = "user",
            Content = userMessage,
            Timestamp = DateTime.Now
        });

        isStreaming = true;
        streamingContent = string.Empty;
        StateHasChanged();

        try
        {
            var responseBuilder = new System.Text.StringBuilder();

            await foreach (var chunk in ChatService.SendMessageAsync(userMessage, currentSessionId))
            {
                streamingContent += chunk;
                responseBuilder.Append(chunk);
                StateHasChanged();
            }

            messages.Add(new ChatMessage
            {
                Role = "assistant",
                Content = responseBuilder.ToString(),
                Timestamp = DateTime.Now
            });
        }
        catch (Exception ex)
        {
            messages.Add(new ChatMessage
            {
                Role = "assistant",
                Content = $"抱歉，发生了错误: {ex.Message}",
                Timestamp = DateTime.Now
            });
        }
        finally
        {
            isStreaming = false;
            streamingContent = string.Empty;
            StateHasChanged();

            await Task.Delay(100);
            await JavaScriptRuntime.InvokeVoidAsync("scrollToBottom", "messagesContainer");
        }
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SendMessage();
        }
    }

    private void SendSuggestion(string suggestion)
    {
        inputText = suggestion;
        StateHasChanged();
    }

    private void ClearChat()
    {
        messages.Clear();
        currentSessionId = ChatService.StartNewSession();
    }

    private void StartNewChat()
    {
        messages.Clear();
        currentSessionId = ChatService.StartNewSession();
        CurrentSessionId = currentSessionId;
        StateHasChanged();
    }

    private void ShowHistory()
    {
        Navigation.NavigateTo("/chat-history");
    }

    private void InputFocused()
    {
        // 键盘弹出时的处理
    }

    private void InputBlurred()
    {
        // 键盘收起时的处理
    }

    private void NavigateToSettings()
    {
        Navigation.NavigateTo("/settings");
    }

    private string RenderMarkdown(string content)
    {
        return MarkdownService.Parse(content);
    }
}
