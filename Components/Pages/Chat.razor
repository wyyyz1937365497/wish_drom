@page "/chat"
@using wish_drom.Models
@using wish_drom.Components.Shared
@inject IChatService ChatService
@inject NavigationManager Navigation

<div class="chat-container">
    <!-- 聊天消息区域 -->
    <div class="messages-area" id="messagesContainer">
        @if (messages.Count == 0)
        {
            <div class="welcome-message">
                <h2>👋 欢迎使用智能校园助手</h2>
                <p>我可以帮您:</p>
                <ul>
                    <li>📚 查询课程安排</li>
                    <li>🎉 查看校园活动</li>
                    <li>📅 管理学习计划</li>
                </ul>
                <p>请先在设置中配置 API Key，然后就可以开始聊天了！</p>
                <button class="btn-primary" @onclick="NavigateToSettings">去设置</button>
                <button class="btn-secondary" @onclick="NavigateToSync">同步数据</button>
            </div>
        }
        else
        {
            @foreach (var message in messages)
            {
                <ChatMessage Role="@message.Role" Content="@message.Content" Timestamp="@message.Timestamp" />
            }
            @if (isStreaming)
            {
                <ChatMessage Role="assistant" Content="@streamingContent" IsStreaming="true" />
            }
        }
    </div>

    <!-- 输入区域 -->
    <div class="input-area">
        @if (isConfigured)
        {
            <div class="input-wrapper">
                <input type="text"
                       class="message-input"
                       placeholder="输入你的问题..."
                       @bind="inputText"
                       @bind:event="oninput"
                       @onkeypress="HandleKeyPress"
                       disabled="isStreaming">
                <button class="send-button" @onclick="SendMessage" disabled="isStreaming || string.IsNullOrEmpty(inputText)">
                    @if (isStreaming)
                    {
                        <span class="spinner">⏳</span>
                    }
                    else
                    {
                        <span>发送</span>
                    }
                </button>
            </div>
        }
        else
        {
            <div class="config-prompt">
                <span>⚠️ 请先配置 API Key</span>
                <button class="btn-small" @onclick="NavigateToSettings">去设置</button>
            </div>
        }
    </div>
</div>

<style>
    .chat-container {
        display: flex;
        flex-direction: column;
        height: 100vh;
        background-color: #f5f5f5;
    }

    .messages-area {
        flex: 1;
        overflow-y: auto;
        padding: 16px;
        scroll-behavior: smooth;
    }

    .welcome-message {
        text-align: center;
        padding: 40px 20px;
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        max-width: 400px;
        margin: 40px auto;
    }

    .welcome-message h2 {
        color: #512BD4;
        margin-bottom: 16px;
    }

    .welcome-message ul {
        text-align: left;
        margin: 20px 0;
        padding-left: 20px;
    }

    .welcome-message li {
        margin: 8px 0;
    }

    .input-area {
        padding: 12px 16px;
        background: white;
        border-top: 1px solid #e0e0e0;
    }

    .input-wrapper {
        display: flex;
        gap: 8px;
        max-width: 800px;
        margin: 0 auto;
    }

    .message-input {
        flex: 1;
        padding: 12px 16px;
        border: 1px solid #ddd;
        border-radius: 24px;
        font-size: 15px;
        outline: none;
        transition: border-color 0.2s;
    }

    .message-input:focus {
        border-color: #512BD4;
    }

    .send-button {
        padding: 12px 24px;
        background-color: #512BD4;
        color: white;
        border: none;
        border-radius: 24px;
        cursor: pointer;
        font-weight: 500;
        transition: background-color 0.2s;
    }

    .send-button:hover:not(:disabled) {
        background-color: #4120a3;
    }

    .send-button:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .config-prompt {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 12px;
        padding: 12px;
        background-color: #fff3cd;
        border-radius: 8px;
        max-width: 400px;
        margin: 0 auto;
    }

    .btn-primary, .btn-secondary, .btn-small {
        padding: 10px 20px;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 500;
        margin: 4px;
    }

    .btn-primary {
        background-color: #512BD4;
        color: white;
    }

    .btn-secondary {
        background-color: #6c757d;
        color: white;
    }

    .btn-small {
        padding: 6px 12px;
        background-color: #512BD4;
        color: white;
    }

    .spinner {
        animation: spin 1s linear infinite;
        display: inline-block;
    }

    @@keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
</style>

@code {
    private List<ChatMessage> messages = new();
    private string inputText = string.Empty;
    private bool isStreaming = false;
    private bool isConfigured = false;
    private string streamingContent = string.Empty;
    private string currentSessionId = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        isConfigured = await ChatService.IsConfiguredAsync();
        if (isConfigured)
        {
            currentSessionId = ChatService.StartNewSession();
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(inputText) || isStreaming)
            return;

        var userMessage = inputText.Trim();
        inputText = string.Empty;

        // 添加用户消息
        messages.Add(new ChatMessage
        {
            Role = "user",
            Content = userMessage,
            Timestamp = DateTime.Now
        });

        // 开始流式响应
        isStreaming = true;
        streamingContent = string.Empty;
        StateHasChanged();

        try
        {
            var responseBuilder = new System.Text.StringBuilder();

            await foreach (var chunk in ChatService.SendMessageAsync(userMessage, currentSessionId))
            {
                streamingContent += chunk;
                responseBuilder.Append(chunk);

                // 每100ms更新一次UI
                await Task.Delay(100);
                StateHasChanged();
            }

            // 添加完整的助手消息
            messages.Add(new ChatMessage
            {
                Role = "assistant",
                Content = responseBuilder.ToString(),
                Timestamp = DateTime.Now
            });
        }
        catch (Exception ex)
        {
            messages.Add(new ChatMessage
            {
                Role = "assistant",
                Content = $"抱歉，发生了错误: {ex.Message}",
                Timestamp = DateTime.Now
            });
        }
        finally
        {
            isStreaming = false;
            streamingContent = string.Empty;
            StateHasChanged();

            // 滚动到底部
            await JavaScriptRuntime.InvokeVoidAsync("scrollToBottom", "messagesContainer");
        }
    }

    private void HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(inputText))
        {
            SendMessage();
        }
    }

    private void NavigateToSettings()
    {
        Navigation.NavigateTo("/settings");
    }

    private void NavigateToSync()
    {
        Navigation.NavigateTo("/sync");
    }
}
